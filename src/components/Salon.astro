---
import { copy, type Locale } from "../data/site";
const { locale = "en" } = Astro.props as { locale?: Locale };
const text = copy[locale].salon;
---

<section class="salon" aria-labelledby="salon-title">
  <div class="frame salon__grid">
    <div>
      <p class="eyebrow">{text.eyebrow}</p>
      <h2 id="salon-title">{text.title}</h2>
      <blockquote set:html={text.quote} />
      <p class="salon__source">{text.source}</p>
    </div>
    <aside>
      <p class="eyebrow">{text.label}</p>
      <p>{text.aside}</p>
    </aside>
  </div>
</section>
