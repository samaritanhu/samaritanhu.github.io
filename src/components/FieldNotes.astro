---
import { copy, fieldNotes, type Locale } from "../data/site";
const { locale = "en" } = Astro.props as { locale?: Locale };
const text = copy[locale].field;
if (fieldNotes.length === 0) return;
---

<section class="frame field-notes" aria-labelledby="field-notes-title">
  <div>
    <p class="eyebrow">{text.eyebrow}</p>
    <h2 id="field-notes-title">{text.title}</h2>
    <div class="field-notes__entries">
      {
        fieldNotes.slice(0, 2).map((note) => (
          <article class="field-note">
            <img src={note.image} alt={note.alt} loading="lazy" />
            <h3>{locale === "zh" ? note.placeZh : note.place}</h3>
            <p class="field-note__caption">“{locale === "zh" ? note.captionZh : note.caption}”</p>
            <a class="field-note__source" href={note.href} target="_blank" rel="noreferrer">
              {locale === "zh" ? note.sourceZh : note.source}
            </a>
          </article>
        ))
      }
    </div>
  </div>
  <aside class="field-notes__aside">
    <p class="eyebrow">{text.archive}</p>
    <p>{text.aside}</p>
  </aside>
</section>
