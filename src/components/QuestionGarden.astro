---
import { copy, type Locale } from "../data/site";
const { locale = "en" } = Astro.props as { locale?: Locale };
const text = copy[locale].question;
---

<section class="frame question-garden" aria-labelledby="question-title">
  <p class="eyebrow">{text.eyebrow}</p>
  <h2 id="question-title" set:html={text.title} />
  <div class="question-garden__meta">
    <p class="eyebrow">{text.label}</p>
    <p>{text.text}</p>
  </div>
</section>
