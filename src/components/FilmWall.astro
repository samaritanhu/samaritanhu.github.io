---
import { copy, type Locale } from "../data/site";
const { locale = "en" } = Astro.props as { locale?: Locale };
const text = copy[locale].film;
---

<section class="film-wall" aria-label={text.aria}>
  <figure><img src="/images/film/patagonia-camper.jpg" alt="A camper beneath the Torres del Paine massif at dusk" loading="lazy" /></figure>
  <figure><img src="/images/film/patagonia-tents.jpg" alt="Yellow tents beneath a mountain in Patagonia" loading="lazy" /></figure>
  <div class="film-wall__copy">
    <h2>{text.title}</h2>
    <p set:html={text.text} />
  </div>
</section>
