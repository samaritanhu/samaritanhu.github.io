---
import { copy, type Locale } from "../data/site";
const { locale = "en" } = Astro.props as { locale?: Locale };
const text = copy[locale].hero;
---

<section class="hero" id="top" aria-labelledby="hero-title">
  <div class="hero__inner frame">
    <div>
      <p class="eyebrow">{text.eyebrow}</p>
      <h1 class:list={[locale === "zh" && "hero__title--zh"]} id="hero-title" set:html={text.title} />
      <p class="hero__lede">{text.lede}</p>
    </div>
    <div class="hero__status">
      <p class="eyebrow">{text.statusLabel}</p>
      <p>{text.status}</p>
    </div>
  </div>
</section>
