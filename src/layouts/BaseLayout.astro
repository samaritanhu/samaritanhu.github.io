---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang?: "en" | "zh";
}

const { title, description, lang = "en" } = Astro.props;
const rssHref = lang === "zh" ? "/zh/rss.xml" : "/rss.xml";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eeece3" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={title} href={rssHref} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
